@model DernekYonetim.Models.HomeViewModel
@{
    ViewData["Title"] = "Etkinlik Albümleri";
    Layout = "_Layout";
}

<section class="page-section bg-light" style="padding-top:120px; padding-bottom: 80px;">
    <div class="container">

        <div class="row align-items-center mb-4 border-bottom border-warning pb-3">
            <div class="col-md-8">
                <h2 class="section-heading text-uppercase mb-0 text-primary-dark">Galeri Albümleri</h2>
                <h3 class="section-subheading text-muted mt-2">Derneğimizin etkinlik arşivi</h3>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                @if (Context.Session.GetInt32("AdminID") != null)
                {
                    <button class="btn btn-gold rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#albumEkleModal">
                        <i class="fas fa-folder-plus me-2"></i>Yeni Albüm Oluştur
                    </button>
                }
            </div>
        </div>

        <div class="row justify-content-center mb-5 mt-4">
            <div class="col-md-10 col-lg-8">
                <form action="/Galeri/Index" method="get" class="d-flex shadow-sm search-bar-wrapper rounded-pill overflow-hidden bg-white border">
                    <div class="d-flex align-items-center ps-4 text-muted">
                        <i class="fas fa-search fs-5 opacity-75"></i>
                    </div>
                    <input type="text" name="arama" value="@ViewBag.AramaKelimesi" class="form-control border-0 px-3 py-3 shadow-none fs-5 bg-transparent" placeholder="Albüm veya etkinlik adı ile ara..." style="outline: none;">
                    <button type="submit" class="btn btn-warning px-5 text-dark fw-bold border-0 fs-5" style="border-radius: 0 50rem 50rem 0; transition: all 0.3s ease;">
                        Ara
                    </button>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.AramaKelimesi))
        {
            <div class="text-center mb-4 text-muted small">
                <strong>"@ViewBag.AramaKelimesi"</strong> için @ViewBag.ToplamKayit sonuç bulundu.
                <a href="/Galeri/Index" class="text-decoration-none ms-2 text-primary-dark fw-bold"><i class="fas fa-times me-1 text-danger"></i>Temizle</a>
            </div>
        }

        <div class="row g-4 mt-2">
            @if (Model.GaleriAlbumleri != null && Model.GaleriAlbumleri.Any())
            {
                foreach (var album in Model.GaleriAlbumleri)
                {
                    <div class="col-lg-4 col-md-6">
                        <a href="/Galeri/Detay/@album.Id" class="text-decoration-none">
                            <div class="card h-100 shadow-sm border-0 gallery-folder-card position-relative">

                                @if (Context.Session.GetInt32("AdminID") != null)
                                {
                                    <div class="admin-controls position-absolute top-0 end-0 m-2" style="z-index: 10;">
                                        <button class="btn btn-light btn-sm shadow rounded-circle me-1" title="Düzenle" data-id="@album.Id" data-baslik="@album.Baslik" data-aciklama="@album.Aciklama" onclick="event.preventDefault(); event.stopPropagation(); editAlbum(this);">
                                            <i class="fas fa-edit text-warning"></i>
                                        </button>
                                        <form action="/Galeri/AlbumSil" method="post" class="d-inline" onsubmit="event.stopPropagation(); return confirm('Bu albümü ve içindeki TÜM fotoğrafları silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@album.Id" />
                                            <button type="submit" class="btn btn-light btn-sm shadow rounded-circle" title="Albümü Sil" onclick="event.preventDefault(); event.stopPropagation(); this.closest('form').submit();">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                }

                                <div class="folder-img-container">
                                    @if (!string.IsNullOrEmpty(album.KapakFotografYolu))
                                    {
                                        <img src="@album.KapakFotografYolu" class="card-img-top" alt="@album.Baslik" style="height:100%; width:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center bg-secondary text-white" style="height:100%;">
                                            <i class="fas fa-folder-open fa-4x opacity-50"></i>
                                        </div>
                                    }
                                </div>

                                <div class="card-body bg-white border-bottom border-warning border-3">
                                    <h5 class="card-title fw-bold text-primary-dark mb-2">
                                        <i class="far fa-folder-open text-warning me-2"></i>@album.Baslik
                                    </h5>
                                    <p class="card-text text-muted small gallery-desc mb-0" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@album.Aciklama</p>
                                </div>
                                <div class="card-footer bg-light border-0 py-2 d-flex justify-content-between align-items-center">
                                    <small class="text-muted fw-bold"><i class="far fa-calendar-alt text-warning me-2"></i> @album.OlusturulmaTarihi.ToString("dd.MM.yyyy")</small>
                                    <small class="text-primary-dark fw-bold"><i class="fas fa-images me-1"></i> @album.Fotograflar.Count</small>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="fas fa-folder-open fa-4x text-muted opacity-50 mb-3"></i>
                    <h5 class="text-primary-dark mt-3">Aradığınız kriterlere uygun albüm bulunamadı.</h5>
                </div>
            }
        </div>

        @if (ViewBag.ToplamSayfa > 1)
        {
            <div class="row mt-5">
                <div class="col-12">
                    <nav aria-label="Sayfa Gezinmesi">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(ViewBag.MevcutSayfa == 1 ? "disabled" : "")">
                                <a class="page-link shadow-sm rounded-circle mx-1 text-dark border-0 bg-white" href="/Galeri/Index?sayfa=@(ViewBag.MevcutSayfa - 1)&arama=@ViewBag.AramaKelimesi">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>

                            @for (int i = 1; i <= ViewBag.ToplamSayfa; i++)
                            {
                                <li class="page-item @(i == ViewBag.MevcutSayfa ? "active" : "")">
                                    <a class="page-link shadow-sm rounded-circle mx-1 border-0 @(i == ViewBag.MevcutSayfa ? "bg-warning text-dark fw-bold" : "bg-white text-dark")" href="/Galeri/Index?sayfa=@i&arama=@ViewBag.AramaKelimesi">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(ViewBag.MevcutSayfa == ViewBag.ToplamSayfa ? "disabled" : "")">
                                <a class="page-link shadow-sm rounded-circle mx-1 text-dark border-0 bg-white" href="/Galeri/Index?sayfa=@(ViewBag.MevcutSayfa + 1)&arama=@ViewBag.AramaKelimesi">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }

    </div>
</section>

@if (Context.Session.GetInt32("AdminID") != null)
{
    <div class="modal fade" id="albumEkleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <form action="/Galeri/AlbumEkle" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-header text-white border-0" style="background-color: #0d2b4d;">
                        <h5 class="modal-title fw-bold"><i class="fas fa-folder-plus text-warning me-2"></i>Yeni Klasör/Albüm Oluştur</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body bg-light">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary-dark">Albüm (Etkinlik) Adı</label>
                            <input type="text" name="Baslik" class="form-control border-0 shadow-sm" required placeholder="Örn: 2026 Bilişim Semineri">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary-dark">Kısa Açıklama</label>
                            <textarea name="Aciklama" class="form-control border-0 shadow-sm" rows="3" placeholder="Etkinlik hakkında kısa bilgi..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary-dark">Klasör Kapak Fotoğrafı</label>
                            <input type="file" name="KapakFotografi" class="form-control border-0 shadow-sm" accept="image/*">
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-gold rounded-pill px-4">Oluştur</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="albumDuzenleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <form action="/Galeri/AlbumDuzenle" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" id="editAlbumId" />
                    <div class="modal-header bg-warning border-0">
                        <h5 class="modal-title text-dark fw-bold"><i class="fas fa-edit me-2"></i>Albümü Düzenle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body bg-light">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary-dark">Albüm Adı</label>
                            <input type="text" name="Baslik" id="editAlbumBaslik" class="form-control border-0 shadow-sm" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary-dark">Açıklama</label>
                            <textarea name="Aciklama" id="editAlbumAciklama" class="form-control border-0 shadow-sm" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary-dark">Yeni Kapak Fotoğrafı</label>
                            <input type="file" name="KapakFotografi" class="form-control border-0 shadow-sm" accept="image/*">
                            <small class="text-muted">Seçmezseniz mevcut fotoğraf korunur.</small>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-gold rounded-pill px-4">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .text-primary-dark {
        color: #0d2b4d !important;
    }

    .btn-gold {
        background-color: #ffc800;
        border-color: #ffc800;
        color: #0d2b4d;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-gold:hover {
            background-color: #e6b400;
            transform: translateY(-2px);
        }

    .gallery-folder-card {
        transition: all 0.4s ease;
        border-radius: 12px;
        background-color: transparent;
        cursor: pointer;
    }

        .gallery-folder-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(13, 43, 77, 0.15) !important;
        }

    .folder-img-container {
        position: relative;
        border-radius: 0 12px 0 0;
        overflow: hidden;
        height: 220px;
        background-color: #e9ecef;
    }

    .admin-controls {
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .gallery-folder-card:hover .admin-controls {
        opacity: 1;
    }

    .search-bar-wrapper:focus-within {
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        border-color: #ffc800 !important;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function editAlbum(btn) {
        document.getElementById('editAlbumId').value = btn.getAttribute('data-id');
        document.getElementById('editAlbumBaslik').value = btn.getAttribute('data-baslik');
        document.getElementById('editAlbumAciklama').value = btn.getAttribute('data-aciklama');
        new bootstrap.Modal(document.getElementById('albumDuzenleModal')).show();
    }
</script>