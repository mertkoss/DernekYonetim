@model DernekYonetim.Models.Haberler
@{
    ViewData["Title"] = Model.Baslik;
    Layout = "_Layout";
}

<section class="page-section bg-white" style="padding-top:100px; padding-bottom: 80px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <a href="/Haberler" class="text-decoration-none text-muted fw-bold">
                        <i class="fas fa-arrow-left me-2"></i> Haberlere Dön
                    </a>
                    @if (Model.Kategori != null)
                    {
                        <span class="badge bg-gold text-dark py-2 px-3 fs-6 shadow-sm">
                            <i class="fas fa-bookmark me-1"></i> @Model.Kategori.KategoriAdi
                        </span>
                    }
                </div>

                <h1 class="text-primary-dark fw-bold mb-3" style="line-height: 1.3;">@Model.Baslik</h1>
                <div class="d-flex align-items-center text-muted mb-4 pb-3 border-bottom border-warning">
                    <i class="far fa-calendar-alt me-2 text-warning fs-5"></i>
                    <span class="fs-6 fw-bold">Yayınlanma Tarihi: @Model.YayimTarihi?.ToString("dd MMMM yyyy")</span>
                </div>

                @if (Context.Session.GetInt32("AdminID") != null)
                {
                    <div class="admin-action-bar bg-light p-3 rounded mb-4 border border-warning d-flex justify-content-between align-items-center shadow-sm">
                        <span class="fw-bold text-primary-dark"><i class="fas fa-user-shield me-2 text-warning"></i>Yönetici İşlemleri</span>
                        <div>
                            <button class="btn btn-sm btn-outline-primary-dark me-2 rounded-pill px-3"
                                    data-bs-toggle="modal" data-bs-target="#detayHaberDuzenleModal" onclick="modalAcildi()">
                                <i class="fas fa-edit me-1"></i> Haberi / Paneli Düzenle
                            </button>
                            <form action="/Haberler/Sil" method="post" class="d-inline" onsubmit="return confirm('Bunu silmek istediğinize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">
                                    <i class="fas fa-trash-alt me-1"></i> Sil
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Ozet))
                {
                    <p class="lead fw-bold text-secondary mb-5" style="font-size: 1.25rem; line-height: 1.6; border-left: 4px solid #ffc800; padding-left: 1rem;">
                        @Model.Ozet
                    </p>
                }

                @if (!string.IsNullOrEmpty(Model.FotografYolu))
                {
                    <div class="mb-5 shadow rounded overflow-hidden">
                        <img src="@Model.FotografYolu" alt="@Model.Baslik" class="img-fluid w-100" style="max-height: 500px; object-fit: cover;" />
                    </div>
                }

                <div class="news-content text-muted fs-5" style="line-height: 1.8; word-wrap: break-word; white-space: pre-wrap;">
                    @Model.Icerik
                </div>

                @if (!string.IsNullOrEmpty(Model.PanelistOzgecmis) || !string.IsNullOrEmpty(Model.CvDosyaYolu))
                {
                    <div class="panelist-profile-card bg-light p-4 rounded-4 mt-5 mb-4 border-start border-5 border-warning shadow-sm">
                        <div class="bg-white p-2 rounded-circle shadow-sm me-3 d-flex justify-content-center align-items-center" style="width: 70px; height: 70px; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(Model.PanelistFotografYolu))
                            {
                                <img src="@Model.PanelistFotografYolu" alt="Panelist Fotoğrafı" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                            }
                            else
                            {
                                <i class="fas fa-user-tie fa-2x text-primary-dark"></i>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model.PanelistOzgecmis))
                        {
                            <p class="text-muted fs-6" style="line-height: 1.7;">
                                @Model.PanelistOzgecmis
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(Model.CvDosyaYolu))
                        {
                            <div class="mt-3 pt-3 border-top border-secondary-subtle">
                                <a href="@Model.CvDosyaYolu" class="btn btn-outline-primary-dark rounded-pill px-4" target="_blank" download>
                                    <i class="fas fa-file-pdf me-2 text-danger"></i> Özgeçmiş Dosyasını İndir / İncele
                                </a>
                            </div>
                        }
                    </div>
                }
                <div class="mt-5 pt-4 border-top border-light d-flex justify-content-between align-items-center">
                    <div class="text-muted small"><strong>Ankara Öğretim Derneği</strong> - Tüm Hakları Saklıdır</div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Context.Session.GetInt32("AdminID") != null)
{
    <div class="modal fade" id="detayHaberDuzenleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <form action="/Haberler/HaberGuncelle" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <div class="modal-header bg-warning text-dark border-0">
                        <h5 class="modal-title fw-bold"><i class="fas fa-edit me-2"></i>Haberi / Paneli Düzenle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4 bg-light">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Haber Başlığı</label>
                                <input type="text" name="Baslik" value="@Model.Baslik" class="form-control border-0 shadow-sm" maxlength="150" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Kategori</label>
                                <select name="KategoriId" class="form-select border-0 shadow-sm" required>
                                    <option value="">Seçiniz...</option>
                                    @if (ViewBag.KategoriListesi != null)
                                    {
                                        foreach (var item in (SelectList)ViewBag.KategoriListesi)
                                        {
                                            if (item.Value == Model.KategoriId.ToString())
                                            {
                                                <option value="@item.Value" selected>@item.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Fotoğrafı Değiştir</label>
                                <input type="file" name="Fotograf" class="form-control border-0 shadow-sm" accept="image/*" />
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Kısa Özet <span class="text-danger">*</span></label>
                                <textarea name="Ozet" id="detayOzet" class="form-control border-0 shadow-sm" rows="2" maxlength="255" oninput="karakterSayici(this, 'detayOzetSayac')" required>@Model.Ozet</textarea>
                                <div class="d-flex justify-content-end mt-1"><small id="detayOzetSayac" class="text-muted fw-bold">0 / 255</small></div>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Haber İçeriği</label>
                                <textarea name="Icerik" class="form-control border-0 shadow-sm" rows="6">@Model.Icerik</textarea>
                            </div>

                            <div class="col-md-12 mb-3 border-top pt-3 mt-2">
                                <h6 class="fw-bold mb-3"><i class="fas fa-user-tie me-2"></i>Panelist Bilgileri</h6>
                                <label class="form-label fw-bold text-primary-dark">Panelist Özgeçmişi</label>
                                <textarea name="PanelistOzgecmis" id="detayPanelistOzgecmis" class="form-control border-0 shadow-sm mb-2" rows="3">@Model.PanelistOzgecmis</textarea>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Panelist Fotoğrafı</label>
                                <input type="file" name="PanelistFotograf" class="form-control border-0 shadow-sm" accept="image/*" />
                                @if (!string.IsNullOrEmpty(Model.PanelistFotografYolu))
                                {
                                    <small class="text-success mt-2 d-block fw-bold"><i class="fas fa-image me-1"></i>Sistemde yüklü bir fotoğraf var.</small>
                                }
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-primary-dark">Yeni CV Dosyası Yükle</label>
                                <input type="file" name="CvDosyasi" class="form-control border-0 shadow-sm" accept=".pdf,.doc,.docx" />
                                @if (!string.IsNullOrEmpty(Model.CvDosyaYolu))
                                {
                                    <small class="text-success mt-2 d-block fw-bold"><i class="fas fa-check-circle me-1"></i>Sistemde yüklü bir CV bulunuyor.</small>
                                }
                            </div>
                            <div class="col-md-12 mb-3">
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input fs-5" type="checkbox" name="SlayttaGoster" value="true" id="detaySlayttaGoster" @(Model.SlayttaGoster ? "checked" : "")>
                                    <label class="form-check-label fw-bold text-primary-dark ms-2 mt-1" for="detaySlayttaGoster">Ana Sayfa Slider'ında Göster</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-gold rounded-pill px-5">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .text-primary-dark {
        color: #0d2b4d !important;
    }

    .bg-gold {
        background-color: #ffc800 !important;
    }

    .btn-gold {
        background-color: #ffc800;
        border-color: #ffc800;
        color: #0d2b4d;
        font-weight: 700;
    }

        .btn-gold:hover {
            background-color: #e6b400;
            border-color: #e6b400;
            color: #000;
        }

    .btn-outline-primary-dark {
        color: #0d2b4d;
        border: 2px solid #0d2b4d;
        background: transparent;
    }

        .btn-outline-primary-dark:hover {
            background: #0d2b4d;
            color: #fff;
        }

    .news-content b, .news-content strong {
        color: #0d2b4d;
    }

    .news-content a {
        color: #ffc800;
        text-decoration: none;
        transition: 0.3s;
    }

        .news-content a:hover {
            color: #0d2b4d;
            text-decoration: underline;
        }

    a.text-muted:hover {
        color: #ffc800 !important;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function karakterSayici(element, sayacId) {
        var max = element.getAttribute("maxlength");
        var mevcut = element.value.length;
        var sayac = document.getElementById(sayacId);

        if(sayac) {
            sayac.innerText = mevcut + " / " + max;
            if (mevcut >= 250) {
                sayac.classList.remove("text-muted"); sayac.classList.add("text-danger", "fw-bold");
            } else {
                sayac.classList.remove("text-danger", "fw-bold"); sayac.classList.add("text-muted");
            }
        }
    }

    function modalAcildi() {
        setTimeout(function() {
            var ozetAlani = document.getElementById('detayOzet');
            if(ozetAlani) { karakterSayici(ozetAlani, 'detayOzetSayac'); }
        }, 200);
    }

    @if (TempData["Basari"] != null)
     {
             <text>
             document.addEventListener('DOMContentLoaded', function() {
                 Swal.fire({
                     icon: 'success', title: 'Başarılı!', text: @Html.Raw(Json.Serialize(TempData["Basari"])), confirmButtonColor: '#0d2b4d'
                 });
             });
             </text>
     }
     @if (TempData["Hata"] != null)
     {
             <text>
             document.addEventListener('DOMContentLoaded', function() {
                 Swal.fire({
                     icon: 'error', title: 'Hata!', text: @Html.Raw(Json.Serialize(TempData["Hata"])), confirmButtonColor: '#0d2b4d'
                 });
             });
             </text>
     }
</script>