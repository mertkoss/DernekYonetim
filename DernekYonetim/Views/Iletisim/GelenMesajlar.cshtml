@model IEnumerable<DernekYonetim.Models.IletisimMesaj>
@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "_Layout";
}

<section class="page-section bg-light" style="padding-top:120px; padding-bottom: 80px; min-height: 80vh;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="section-heading text-primary-dark mb-0 fw-bold">
                    <i class="fas fa-inbox text-warning me-2"></i>Gelen Mesajlar
                </h2>
                <p class="text-muted mt-2">Web sitesi iletişim formundan gelen mesajlar.</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover align-middle mb-0" style="table-layout: fixed; min-width: 950px;">
                    <thead class="bg-primary-dark text-white">
                        <tr>
                            <th class="py-3 ps-4" style="width: 8%;">Durum</th>
                            <th class="py-3" style="width: 18%;">Gönderen</th>
                            <th class="py-3" style="width: 22%;">E-Posta</th>
                            <th class="py-3" style="width: 24%;">Konu</th>
                            <th class="py-3" style="width: 13%;">Tarih</th>
                            <th class="py-3 pe-4 text-end" style="width: 15%;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var mesaj in Model)
                            {
                                <tr class="@(!mesaj.OkunduMu ? "bg-light-warning fw-bold" : "")">
                                    <td class="ps-4 text-center">
                                        @if (!mesaj.OkunduMu)
                                        {
                                            <span class="badge bg-danger rounded-circle p-2" title="Yeni Mesaj"><span class="visually-hidden">Yeni</span></span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-check text-success" title="Okundu"></i>
                                        }
                                    </td>
                                    <td class="text-truncate" title="@mesaj.AdSoyad">@mesaj.AdSoyad</td>
                                    <td class="text-truncate" title="@mesaj.Eposta">
                                        <a href="mailto:@mesaj.Eposta" class="text-decoration-none">@mesaj.Eposta</a>
                                    </td>
                                    <td class="text-truncate" title="@mesaj.Konu">@mesaj.Konu</td>
                                    <td class="text-muted small">@mesaj.GonderilmeTarihi.ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="pe-4">
                                        <div class="d-flex justify-content-end align-items-center gap-2">
                                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                    onclick="mesajOku(@mesaj.Id, '@Html.Raw(mesaj.AdSoyad)', '@Html.Raw(mesaj.Eposta)', '@Html.Raw(mesaj.Konu.Replace("'", "\\'"))', '@Html.Raw(mesaj.Mesaj.Replace("\r\n", "<br>").Replace("\n", "<br>").Replace("'", "\\'"))', '@mesaj.GonderilmeTarihi.ToString("dd.MM.yyyy HH:mm")')">
                                                Oku
                                            </button>
                                            <form action="/Iletisim/MesajSil" method="post" class="m-0 p-0" onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@mesaj.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0 fs-5">Henüz hiç mesajınız yok.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="mesajOkuModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary-dark text-white border-0 rounded-top-4">
                <h5 class="modal-title fw-bold"><i class="fas fa-envelope-open-text me-2 text-warning"></i>Mesaj Detayı</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 p-md-5 bg-light">
                <div class="row mb-4 border-bottom pb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Gönderen</small>
                        <strong class="fs-5 text-dark text-break" id="modalAdSoyad"></strong>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Tarih</small>
                        <span class="text-dark" id="modalTarih"></span>
                    </div>
                </div>
                <div class="row mb-4 border-bottom pb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">E-Posta</small>
                        <a href="" id="modalEpostaLink" class="fw-bold text-decoration-none text-primary text-break"></a>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Konu</small>
                        <strong class="text-dark text-break" id="modalKonu"></strong>
                    </div>
                </div>
                <div>
                    <small class="text-muted text-uppercase fw-bold d-block mb-2">Mesaj İçeriği</small>
                    <div class="bg-white p-4 border rounded-3 text-dark text-break" id="modalMesaj" style="line-height: 1.8; max-height: 350px; overflow-y: auto;">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-white rounded-bottom-4">
                <a href="" id="modalYanitlaBtn" class="btn btn-gold rounded-pill px-4 fw-bold">
                    <i class="fas fa-reply me-2"></i>Mail ile Yanıtla
                </a>
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-dark {
        background-color: #0d2b4d !important;
    }

    .text-primary-dark {
        color: #0d2b4d !important;
    }

    .bg-light-warning {
        background-color: rgba(255, 200, 0, 0.08) !important;
    }

    .btn-gold {
        background-color: #ffc800;
        border-color: #ffc800;
        color: #0d2b4d;
    }

        .btn-gold:hover {
            background-color: #e6b400;
            color: #000;
        }
</style>

<script>
    function mesajOku(id, adSoyad, eposta, konu, mesaj, tarih) {
        // Modal bilgilerini doldur
        document.getElementById('modalAdSoyad').innerText = adSoyad;
        document.getElementById('modalEpostaLink').innerText = eposta;
        document.getElementById('modalEpostaLink').href = "mailto:" + eposta;
        document.getElementById('modalKonu').innerText = konu;
        document.getElementById('modalMesaj').innerHTML = mesaj;
        document.getElementById('modalTarih').innerText = tarih;
        document.getElementById('modalYanitlaBtn').href = "mailto:" + eposta + "?subject=RE: " + konu;

        // Modalı göster
        var myModal = new bootstrap.Modal(document.getElementById('mesajOkuModal'));
        myModal.show();

        // Arka planda okundu olarak işaretle
        fetch('/Iletisim/MesajOkunduIsaretle', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'id=' + id
        }).then(response => {
            if (response.ok) {
                // Sayfayı sen okurken DEĞİL, modalı kapattığında yenile
                var modalElement = document.getElementById('mesajOkuModal');
                modalElement.addEventListener('hidden.bs.modal', function () {
                    window.location.reload();
                }, { once: true });
            }
        });
    }
</script>