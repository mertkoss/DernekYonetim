@using DernekYonetim.Models
@inject DernekYonetimContext DbContext

<style>
    /* SADECE MOBİL VE TABLET İÇİN DÜZENLEME (1200px altı) */
    @@media (max-width: 1199.98px) {
        #navbarNav

    {
        background-color: #ffffff;
        padding: 15px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        margin-top: 10px;
        border: 1px solid #eee;
    }

    /* Alt menülerin mobildeki girintisi ve arka planı */
    .navbar-nav .dropdown-menu {
        border: none;
        background-color: #f8f9fa;
        padding-left: 15px;
        margin-top: 5px;
    }

    /* Admin profili veya Giriş butonunun margin'lerini mobilde sıfırla */
    .navbar-nav .ms-xl-3,
    .navbar-nav .ms-xl-2 {
        margin-left: 0 !important;
        margin-top: 10px;
    }

    /* Dropdown içeriğinin mobilde sola yaslanması */
    .dropdown-menu-end {
        text-align: left !important;
    }

    }
</style>

<nav class="navbar navbar-expand-xl navbar-light navbar-custom">
    <div class="container">
        <a class="navbar-brand" href="/">
            <img src="~/lib/img/logos/logo.jpeg" alt="logo" style="height:60px; margin-right:10px;" />
            Ankara Öğretim Derneği
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav align-items-center">

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Dernek Hakkında
                    </a>
                    <ul class="dropdown-menu shadow border-0" aria-labelledby="navbarDropdown">
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/tarihce">Tarihçe</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/yonetim-kurulu">Yönetim Kurulu</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/denetim-kurulu">Denetim Kurulu</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/onur-kurulu">Genel Kurul</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/vizyonumuz">Vizyonumuz</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/misyonumuz">Misyonumuz</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/isletme-hesabi">İşletme Hesabı Tablosu</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/tuzuk">Tüzük</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/dernekler-kanunu">Dernekler Kanunu</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/dernekler-yonetmeligi">Dernekler Yönetmeliği</a></li>
                        <li><hr class="dropdown-divider"></li>

                        @if (Context.Session.GetInt32("AdminID") != null)
                        {
                            <li>
                                <a class="dropdown-item fw-bold text-primary" href="/Aidatlar/Index">
                                    <i class="fas fa-cog me-1"></i> Aidat Yönetimi (Admin)
                                </a>
                            </li>
                        }

                        <li>
                            <a class="dropdown-item" href="/Dernek/Hakkinda/aidatlar">
                                Yıllık Aidatlarımız
                            </a>
                        </li>

                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/banka-hesaplari">Banka Hesapları</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/uyeler-aydinlatma">Üyeler İçin Aydınlatma Metni</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/ziyaretci-aydinlatma">Ziyaretçiler İçin Aydınlatma Metni</a></li>
                        <li><a class="dropdown-item" href="/Dernek/Hakkinda/cerez-politikasi">Çerez Politikası</a></li>
                    </ul>
                </li>

                <li class="nav-item"><a class="nav-link" href="/Galeri">Galeri</a></li>
                <li class="nav-item"><a class="nav-link" href="/Kayiplar/Index">Kaybettiklerimiz</a></li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="haberlerDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Haberler
                    </a>
                    <ul class="dropdown-menu shadow border-0" aria-labelledby="haberlerDropdown">
                        <li><a class="dropdown-item fw-bold" href="/Haberler">Tüm Haberler</a></li>
                        <li><hr class="dropdown-divider"></li>

                        @foreach (var kat in DbContext.HaberKategorileris.ToList())
                        {
                            <li><a class="dropdown-item" href="/Haberler/Kategori/@kat.Id">@kat.KategoriAdi</a></li>
                        }
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link" href="/Iletisim/Index">İletişim</a></li>

                @if (Context.Session.GetInt32("AdminID") != null)
                {
                    <li class="nav-item dropdown ms-xl-3">
                        <a class="nav-link dropdown-toggle fw-bold text-primary-dark" href="#" id="userProfileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i id="navProfileIcon" class="fas fa-user-circle fs-5 me-1 text-warning align-middle"></i>
                            @Context.Session.GetString("AdminAd")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2" aria-labelledby="userProfileDropdown" style="min-width: 220px;">

                            <li class="px-3 py-2 text-center border-bottom mb-2 bg-light">
                                <i id="dropdownProfileIcon" class="fas fa-user-shield fa-2x text-muted mb-2"></i>
                                <h6 class="mb-0 fw-bold">@Context.Session.GetString("AdminAd")</h6>
                                <small class="text-muted fw-bold">
                                    @(Context.Session.GetString("AdminRol") == "SuperAdmin" ? "Süper Yönetici" : "Yönetici")
                                </small>
                            </li>

                            @if (Context.Session.GetString("AdminRol") == "SuperAdmin")
                            {
                                <li>
                                    <a class="dropdown-item py-2" href="/Auth/AdminListesi">
                                        <i class="fas fa-users-cog me-2 w-15px text-primary"></i> Yöneticileri Yönet
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item py-2" href="/Log/Index">
                                        <i class="fas fa-clipboard-list me-2 w-15px text-info"></i> Sistem Logları
                                    </a>
                                </li>
                            }

                            <li>
                                <a class="dropdown-item py-2 fw-bold text-success" href="/Iletisim/GelenMesajlar">
                                    <i class="fas fa-envelope me-2 w-15px"></i> Gelen Mesajlar
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item py-2" href="/Profil/Index">
                                    <i class="fas fa-user-edit me-2 w-15px"></i> Profilimi Güncelle
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item py-2" href="/Profil/SifreDegistir">
                                    <i class="fas fa-key me-2 w-15px"></i> Şifre Değiştir
                                </a>
                            </li>

                            <li><hr class="dropdown-divider my-2"></li>

                            <li>
                                <a class="dropdown-item py-2 text-danger fw-bold" href="/Auth/Logout"
                                   onclick="return confirm('Sistemden çıkış yapmak istediğinize emin misiniz?');">
                                    <i class="fas fa-sign-out-alt me-2 w-15px"></i> Güvenli Çıkış Yap
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item ms-xl-2">
                        <a class="nav-link btn btn-outline-warning rounded-pill px-4 text-dark fw-bold" href="/Auth/Login">
                            <i class="fa fa-user me-1"></i>
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>