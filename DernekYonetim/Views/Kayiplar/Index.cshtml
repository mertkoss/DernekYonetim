@model IEnumerable<DernekYonetim.Models.Kaybettiklerimiz>
@{
    ViewData["Title"] = "Kaybettiklerimiz";
    Layout = "_Layout";
}

<section class="page-section bg-light" style="padding-top:120px; padding-bottom: 100px;">
    <div class="container">
        <div class="text-center mb-5 pb-4 border-bottom border-secondary border-opacity-25">
            <h2 class="section-heading text-primary-dark text-uppercase mb-3" style="letter-spacing: 2px;">Kaybettiklerimiz</h2>
            <p class="text-muted fs-5 fst-italic mb-4">"Aramızdan ayrılan değerli büyüklerimizi ve dostlarımızı sevgi, saygı ve özlemle anıyoruz..."</p>

            <div class="row justify-content-center mt-4">
                <div class="col-md-8 col-lg-6">
                    <form action="/Kayiplar/Index" method="get" class="d-flex shadow-sm rounded-pill overflow-hidden bg-white" onsubmit="return false;">
                        <input type="text" id="canliAramaKutusu" name="arama" value="@ViewBag.AramaKelimesi" class="form-control border-0 px-4 py-3 shadow-none" placeholder="İsim veya kelime ile ara..." style="outline: none;">
                        <button type="button" class="btn btn-warning px-4 text-dark fw-bold border-0" style="border-radius: 0 50rem 50rem 0; cursor: default;">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>
            </div>

            @if (Context.Session.GetInt32("AdminID") != null)
            {
                <button class="btn btn-dark rounded-pill mt-4 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#kayipEkleModal">
                    <i class="fas fa-plus me-2"></i>Yeni Kayıt Ekle
                </button>
            }
        </div>

        <div id="aramaSonuclariAlani" style="transition: opacity 0.3s ease;">
            @await Html.PartialAsync("_KayiplarListesiPartial", Model)
        </div>
    </div>
</section>

<div class="modal fade" id="tributeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 pb-0 position-absolute w-100" style="z-index: 10;">
                <button type="button" class="btn-close btn-close-white bg-dark bg-opacity-50 p-2 rounded-circle ms-auto m-3" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="row g-0">
                    <div class="col-md-5 bg-dark d-flex align-items-center justify-content-center p-4">
                        <img id="tributeImg" src="" alt="" class="img-fluid rounded-circle shadow border border-3 border-secondary" style="width: 200px; height: 200px; object-fit: cover;">
                    </div>
                    <div class="col-md-7 p-5 bg-white">
                        <h2 id="tributeName" class="fw-bold text-primary-dark mb-2"></h2>
                        <div class="text-muted mb-4 pb-3 border-bottom d-flex align-items-center" style="font-size: 0.95rem;">
                            <div id="birthWrapper" style="display: none;">
                                <i class="fas fa-star text-warning me-2"></i><span id="tributeBirthYear" class="fw-medium"></span>
                                <span class="mx-3 text-secondary opacity-50">•</span>
                            </div>
                            <div>
                                <i class="fas fa-dove text-secondary me-2"></i><span id="tributeExactDate" class="fw-medium"></span>
                            </div>
                        </div>
                        <div class="custom-scrollbar pe-2" style="max-height: 300px; overflow-y: auto;">
                            <p id="tributeText" class="text-secondary" style="white-space: pre-wrap; line-height: 1.8;"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Context.Session.GetInt32("AdminID") != null)
{
    <div class="modal fade" id="kayipDuzenleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <form action="/Kayiplar/KayitGuncelle" method="post" onsubmit="return validateDates(this)" enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" id="editId" />
                    <div class="modal-header bg-warning text-dark border-0">
                        <h5 class="modal-title fw-bold">Kaydı Düzenle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body bg-light p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ad Soyad</label>
                            <input type="text" name="AdSoyad" id="editAdSoyad" class="form-control border-0 shadow-sm" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Doğum Tarihi</label>
                                <input type="date" name="DogumTarihiInput" id="editDogumTarihi" class="form-control border-0 shadow-sm">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Vefat Tarihi</label>
                                <input type="date" name="VefatTarihiInput" id="editVefatTarihi" class="form-control border-0 shadow-sm" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Fotoğrafı Değiştir</label>
                            <input type="file" name="Fotograf" class="form-control border-0 shadow-sm" accept="image/*">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Açıklama / Özgeçmiş</label>
                            <textarea name="Aciklama" id="editAciklama" class="form-control border-0 shadow-sm" rows="5"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-warning rounded-pill px-4">Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="kayipEkleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <form action="/Kayiplar/KayitEkle" method="post" onsubmit="return validateDates(this)" enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="modal-header bg-dark text-white border-0">
                        <h5 class="modal-title fw-bold"><i class="fas fa-plus me-2 text-warning"></i>Yeni Kayıt Ekle</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body bg-light p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ad Soyad</label>
                            <input type="text" name="AdSoyad" class="form-control border-0 shadow-sm" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Doğum Tarihi</label>
                                <input type="date" name="DogumTarihiInput" id="addDogumTarihi" class="form-control border-0 shadow-sm">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Vefat Tarihi</label>
                                <input type="date" name="VefatTarihiInput" id="addVefatTarihi" class="form-control border-0 shadow-sm" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Fotoğraf</label>
                            <input type="file" name="Fotograf" class="form-control border-0 shadow-sm" accept="image/*">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Açıklama / Özgeçmiş</label>
                            <textarea name="Aciklama" class="form-control border-0 shadow-sm" rows="5"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" class="btn btn-dark rounded-pill px-4">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .text-primary-dark {
        color: #0d2b4d !important;
    }

    .memorial-row {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
    }

        .memorial-row:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08) !important;
        }

    .memorial-img-container {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        padding: 5px;
        background: #fff;
        border: 2px solid #e9ecef;
    }

        .memorial-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(100%);
            transition: filter 0.5s ease;
        }

    .memorial-row:hover .memorial-img-container img {
        filter: grayscale(0%);
    }

    .memorial-desc {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .admin-controls {
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .memorial-row:hover .admin-controls {
        opacity: 1;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #d1d1d1;
        border-radius: 4px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8;
        }

    .page-item.active .page-link {
        z-index: 3;
        color: #000;
        background-color: #ffc107;
        border-color: #ffc107;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const aramaKutusu = document.getElementById('canliAramaKutusu');
    const sonuclarAlani = document.getElementById('aramaSonuclariAlani');
    let aramaZamanlayici;

    if(aramaKutusu && sonuclarAlani) {
        aramaKutusu.addEventListener('input', function() {
            clearTimeout(aramaZamanlayici);
            const kelime = this.value;
            sonuclarAlani.style.opacity = '0.5';

            aramaZamanlayici = setTimeout(() => {
                const url = `/Kayiplar/Index?arama=${encodeURIComponent(kelime)}`;

                // AJAX ISTEGI (DOMParser iptal edildi)
                fetch(url, { headers: { "X-Requested-With": "XMLHttpRequest" } })
                    .then(response => response.text())
                    .then(html => {
                        sonuclarAlani.innerHTML = html;
                        sonuclarAlani.style.opacity = '1';
                        window.history.pushState({}, '', url);
                    })
                    .catch(error => {
                        console.error("Arama hatası:", error);
                        sonuclarAlani.style.opacity = '1';
                    });
            }, 400);
        });
    }

    function bindDateLimits(dogumId, vefatId) {
        const dogumInput = document.getElementById(dogumId);
        const vefatInput = document.getElementById(vefatId);
        if(dogumInput && vefatInput) {
            dogumInput.addEventListener('change', function() {
                if(this.value) vefatInput.min = this.value;
            });
            vefatInput.addEventListener('change', function() {
                if(this.value) dogumInput.max = this.value;
            });
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        bindDateLimits('addDogumTarihi', 'addVefatTarihi');
        bindDateLimits('editDogumTarihi', 'editVefatTarihi');
    });

    function openTributeModal(btn) {
        document.getElementById('tributeName').innerText = btn.getAttribute('data-adsoyad');
        document.getElementById('tributeImg').src = btn.getAttribute('data-img');
        document.getElementById('tributeText').innerText = btn.getAttribute('data-aciklama');

        const dogumYil = btn.getAttribute('data-dogum-yili');
        const vefatTam = btn.getAttribute('data-vefat-tam');
        const birthWrapper = document.getElementById('birthWrapper');

        if (dogumYil && dogumYil !== "") {
            document.getElementById('tributeBirthYear').innerText = dogumYil;
            birthWrapper.style.display = 'inline-block';
        } else {
            birthWrapper.style.display = 'none';
        }
        document.getElementById('tributeExactDate').innerText = vefatTam;

        var tributeModal = new bootstrap.Modal(document.getElementById('tributeModal'));
        tributeModal.show();
    }

    function kayipDuzenle(btn) {
        let dogumTarihi = btn.getAttribute('data-dogum');
        let vefatTarihi = btn.getAttribute('data-tarih');
        let dogumInput = document.getElementById('editDogumTarihi');
        let vefatInput = document.getElementById('editVefatTarihi');

        document.getElementById('editId').value = btn.getAttribute('data-id');
        document.getElementById('editAdSoyad').value = btn.getAttribute('data-adsoyad');
        dogumInput.value = dogumTarihi;
        vefatInput.value = vefatTarihi;
        document.getElementById('editAciklama').value = btn.getAttribute('data-aciklama');

        vefatInput.min = dogumTarihi ? dogumTarihi : '';
        dogumInput.max = vefatTarihi ? vefatTarihi : '';

        var editModal = new bootstrap.Modal(document.getElementById('kayipDuzenleModal'));
        editModal.show();
    }

    function validateDates(form) {
        const dogum = form.querySelector('input[name="DogumTarihiInput"]').value;
        const vefat = form.querySelector('input[name="VefatTarihiInput"]').value;
        if (dogum && vefat && new Date(vefat) < new Date(dogum)) {
            Swal.fire({ icon: 'error', title: 'Hata!', text: 'Vefat tarihi doğum tarihinden önce olamaz!', confirmButtonColor: '#0d2b4d' });
            return false;
        }
        return true;
    }

    // UYARI MESAJLARI (JSON FORMATINDA GÜVENLİ)
    @if (TempData["Basari"] != null)
    {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({ icon: 'success', title: 'Başarılı!', text: @Html.Raw(Json.Serialize(TempData["Basari"])), confirmButtonColor: '#0d2b4d' });
            });
            </text>
    }
    @if (TempData["Hata"] != null)
    {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({ icon: 'error', title: 'Hata!', text: @Html.Raw(Json.Serialize(TempData["Hata"])), confirmButtonColor: '#0d2b4d' });
            });
            </text>
    }
</script>