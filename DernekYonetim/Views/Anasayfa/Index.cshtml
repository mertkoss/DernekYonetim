@using DernekYonetim.Models
@model DernekYonetim.Models.HomeViewModel

@{
    ViewData["Title"] = "Anasayfa";
    Layout = "_Layout";
}

<style>
    /* GENEL DEĞİŞKENLER */
    :root {
        --renk-lacivert: #0a1a5c;
        --renk-altin: #b8860b;
        --renk-acik-altin: #d4a017;
        --renk-gri: #f8fafc;
    }

   /* YENİ PROFESYONEL SLIDER AYARLARI */
    .hero-section {
        position: relative;
        width: 100%;
        height: 85vh !important;
        min-height: 650px;
        overflow: hidden;
    }

    .carousel, .carousel-inner, .carousel-item {
        height: 100% !important;
    }

    .carousel-item {
        background-size: cover !important;
        background-position: center center !important;
        background-repeat: no-repeat !important;
        transition: transform 6s ease, opacity 1s ease-in-out !important; 
    }

    .carousel-item.active {
        transform: scale(1.05);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(10, 26, 92, 0.95) 0%, rgba(10, 26, 92, 0.7) 40%, rgba(10, 26, 92, 0.1) 100%);
        z-index: 1;
    }

    /* Yazı içeriği artık sola yapışmayacak */
    .hero-content {
        position: relative;
        z-index: 2;
        color: white;
        opacity: 0; 
        transform: translateY(30px); 
        animation: fadeUp 1s ease-out forwards;
        animation-delay: 0.5s; 
    }

    @@keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .carousel-item.active .hero-content {
        animation: fadeUp 1s ease-out forwards;
        animation-delay: 0.3s;
    }

    .hero-content .badge {
        font-size: 0.9rem;
        letter-spacing: 2px;
        margin-bottom: 20px;
        background-color: var(--renk-altin);
        color: var(--renk-lacivert);
        padding: 8px 15px;
    }

    .hero-content h1 {
        font-family: 'Playfair Display', serif;
        font-size: 4.5rem; /* Biraz daha büyüttük */
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 20px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.3);
    }

    .hero-content p {
        font-size: 1.25rem;
        line-height: 1.8;
        opacity: 0.9;
        margin-bottom: 35px;
        border-left: 4px solid var(--renk-altin);
        padding-left: 20px; /* Çizgi ile yazı arasına nefes payı */
    }

    .btn-hero {
        background-color: var(--renk-altin);
        color: var(--renk-lacivert);
        font-weight: 700;
        letter-spacing: 1px;
        padding: 12px 35px;
        border-radius: 50px;
        transition: all 0.3s ease;
        border: 2px solid var(--renk-altin);
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .btn-hero:hover {
        background-color: transparent;
        color: var(--renk-altin);
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(184, 134, 11, 0.3);
    }

    /* ---- YENİ PROFESYONEL İNDİKATÖR (KAPSÜL NOKTALAR) ---- */
    .carousel-indicators {
        margin-bottom: 2.5rem;
        gap: 8px; /* Noktalar arası mesafe */
    }

    .carousel-indicators button {
        width: 10px !important;
        height: 10px !important;
        border-radius: 50% !important; /* Yuvarlak nokta */
        background-color: rgba(255, 255, 255, 0.4) !important;
        border: none !important;
        margin: 0 !important;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .carousel-indicators button.active {
        width: 35px !important; /* Aktif olunca uzar (kapsül) */
        border-radius: 10px !important;
        background-color: var(--renk-altin) !important;
    }

    /* ---- OKLARIN KONUMU DÜZELTİLDİ ---- */
    .carousel-control-prev, .carousel-control-next {
        width: 50px;
        height: 50px;
        background-color: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        transition: all 0.3s ease;
        opacity: 0;
    }

    /* Ekranın en sağına ve soluna sabitlendi */
    .carousel-control-prev { left: 2%; }
    .carousel-control-next { right: 2%; }

    .hero-section:hover .carousel-control-prev, 
    .hero-section:hover .carousel-control-next {
        opacity: 1;
    }

    .carousel-control-prev:hover, .carousel-control-next:hover {
        background-color: var(--renk-altin);
        border-color: var(--renk-altin);
        color: var(--renk-lacivert);
    }

    @@media (max-width: 991px) {
        .hero-content h1 { font-size: 3rem; }
        .carousel-control-prev, .carousel-control-next { display: none; }
        .overlay { background: linear-gradient(to top, rgba(10, 26, 92, 0.95) 0%, rgba(10, 26, 92, 0.6) 60%, rgba(10, 26, 92, 0.2) 100%); }
    }

    /* İSTATİSTİK BÖLÜMÜ */
    .stats-section {
        background-color: var(--renk-lacivert);
        color: white;
        padding: 60px 0;
    }

    .stat-item {
        text-align: center;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
    }

    .stat-label {
        color: var(--renk-altin);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 5px;
    }

    .stat-icon i {
        font-size: 2.5rem;
        color: var(--renk-altin);
        margin-bottom: 15px;
    }

    /* Görsellerin kart içinde düzgün ve aynı boyutta durmasını sağlar */
.school-card .card-img-top {
    height: 250px;
    object-fit: cover;
    border-radius: 8px 8px 0 0;
}

/* Kartların üzerine gelindiğinde oluşan animasyon */
.school-card {
    border-radius: 8px;
    transition: all 0.3s ease-in-out;
}

.school-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 20px rgba(10, 26, 92, 0.15) !important;
}

/* Link yazılarının mavi veya altı çizili olmasını engeller */
.text-decoration-none {
    text-decoration: none !important;
}
   

   .heritage-image-wrapper {
        width: 100%;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        /* İçerik kutusunun bunun üzerine çıkmasına yer açmak için alt marjin */
        margin-bottom: 0; 
    }

    .heritage-img {
        width: 100%;
        height: auto;
        display: block;
        /* Tarihi havayı artırmak için CSS ile hafif siyah-beyaz ve sepya tonu (İsteğe bağlı) */
        filter: grayscale(80%) contrast(110%);
    }

    .heritage-content-card {
        background: white;
        padding: 50px;
        border-radius: 20px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.08);
        position: relative;
        z-index: 10;
        /* SİHİRLİ DOKUNUŞ: Kutuyu yukarı, fotoğrafın üzerine çeker */
        margin-top: -100px; 
    }

    /* Özel Tarihçe Butonu Hover Efekti */
    .btn-heritage {
        border: 2px solid var(--renk-lacivert);
        color: var(--renk-lacivert);
        background-color: transparent;
        transition: all 0.3s ease-in-out;
    }

    .btn-heritage:hover {
        background-color: var(--renk-altin);
        border-color: var(--renk-altin);
        color: #ffffff !important;
    }
    
    @@media (max-width: 768px) {
        .heritage-content-card {
            margin-top: -50px;
            padding: 30px 20px;
        }
    }

    /* ANA SAYFA HABERLER BÖLÜMÜ ÖZEL STİLLERİ */
    .object-fit-cover {
        object-fit: cover;
    }

    /* Manşet Haberi Efektleri */
    .main-featured-news {
        min-height: 450px;
    }

    .main-news-img {
        transition: transform 0.6s ease;
    }

    .news-gradient-overlay {
        background: linear-gradient(to top, rgba(10, 26, 92, 0.95) 0%, rgba(10, 26, 92, 0.4) 50%, rgba(0, 0, 0, 0) 100%);
        transition: background 0.4s ease;
    }

    .main-featured-news:hover .main-news-img {
        transform: scale(1.05); /* Üzerine gelince resim hafifçe büyür */
    }

    .main-featured-news:hover .news-gradient-overlay {
        background: linear-gradient(to top, rgba(10, 26, 92, 0.95) 0%, rgba(10, 26, 92, 0.6) 60%, rgba(0, 0, 0, 0) 100%);
    }

    .main-news-content h3 {
        transition: color 0.3s;
    }

    .main-featured-news:hover .main-news-content h3 {
        color: var(--renk-altin) !important; /* Üzerine gelince başlık sarı olur */
    }

    /* Yan Akış Haberi Efektleri */
    .transition-all {
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

    .side-news-card:hover {
        transform: translateY(-5px); /* Kart hafifçe yukarı kalkar */
        border-color: rgba(184, 134, 11, 0.3); /* Kenarlık hafif sarımsı olur */
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }

    .side-news-img-wrapper img {
        transition: transform 0.5s ease;
    }

    .side-news-card:hover .side-news-img-wrapper img {
        transform: scale(1.1);
    }
    
    .side-news-card h6 {
        transition: color 0.3s;
    }

    .side-news-card:hover h6 {
        color: var(--renk-altin) !important;
    }
</style>

<header class="hero-section">
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="6000">
        
        <div class="carousel-indicators">
            @if (Model.SliderHaberler != null && Model.SliderHaberler.Any())
            {
                for (int i = 0; i < Model.SliderHaberler.Count; i++)
                {
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                }
            }
            else
            {
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            }
        </div>

        <div class="carousel-inner">
            @if (Model.SliderHaberler != null && Model.SliderHaberler.Any())
            {
                var isFirst = true;
                foreach (var sliderItem in Model.SliderHaberler)
                {
                    <div class="carousel-item @(isFirst ? "active" : "")" style="background-image: url('@(string.IsNullOrEmpty(sliderItem.FotografYolu) ? "/img/default-news.jpg" : sliderItem.FotografYolu)');">
                        <div class="overlay">
                            <div class="container h-100">
                                <div class="row h-100 align-items-center">
                                    <div class="col-12 col-md-10 col-lg-8 offset-lg-1 px-4 px-md-0">
                                        
                                        <div class="hero-content">
                                            <span class="badge text-uppercase rounded-pill shadow-sm">
                                                <i class="fas fa-bullhorn me-1"></i> GÜNCEL GELİŞME
                                            </span>
                                            <h1>
                                                @if(sliderItem.Baslik.Length > 40)
                                                {
                                                    @sliderItem.Baslik.Substring(0, 40)<span style="color:var(--renk-altin);">...</span>
                                                }
                                                else
                                                {
                                                    var kelimeler = sliderItem.Baslik.Split(' ');
                                                    if(kelimeler.Length > 1) {
                                                        var sonKelime = kelimeler[kelimeler.Length - 1];
                                                        var digerKelimeler = string.Join(" ", kelimeler.Take(kelimeler.Length - 1));
                                                        @digerKelimeler <span style="color:var(--renk-altin);">@sonKelime</span>
                                                    } else {
                                                        @sliderItem.Baslik
                                                    }
                                                }
                                            </h1>
                                            <p>
                                                @(sliderItem.Ozet.Length > 150 ? sliderItem.Ozet.Substring(0, 150) + "..." : sliderItem.Ozet)
                                            </p>
                                            <a href="/Haberler/Detay/@sliderItem.Id" class="btn btn-hero">
                                                Haberi İncele <i class="fas fa-arrow-right ms-2"></i>
                                            </a>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    isFirst = false;
                }
            }
            else
            {
                <div class="carousel-item active" style="background-image: url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=2070');">
                    <div class="overlay">
                        <div class="container h-100">
                            <div class="row h-100 align-items-center">
                                <div class="col-12 col-md-10 col-lg-8 offset-lg-1 px-4 px-md-0">
                                    
                                    <div class="hero-content">
                                        <span class="badge text-uppercase rounded-pill shadow-sm">
                                            <i class="fas fa-university me-1"></i> ANKARA ÖĞRETİM DERNEĞİ
                                        </span>
                                        <h1>Eğitimde <span style="color:var(--renk-altin);">Fırsat Eşitliği</span></h1>
                                        <p>Yarım asırdır aydınlık nesiller yetiştirmek için çalışıyoruz. Geleceğe atılan her adımda, Atatürk ilke ve inkılaplarının ışığında yanınızdayız.</p>
                                        <a href="/Dernek/Hakkinda/tarihce" class="btn btn-hero">
                                            Tarihçemizi Keşfet <i class="fas fa-arrow-right ms-2"></i>
                                        </a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <i class="fas fa-chevron-left fs-4"></i>
            <span class="visually-hidden">Önceki</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <i class="fas fa-chevron-right fs-4"></i>
            <span class="visually-hidden">Sonraki</span>
        </button>
    </div>
</header>



<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-icon"><i class="fa fa-graduation-cap"></i></div>

                    <div class="stat-number counter" data-count="1965">0</div>

                    <div class="stat-label">Kuruluş Yılı</div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-icon"><i class="fa fa-users"></i></div>

                    <div class="stat-number counter" data-count="5000" data-suffix="+">0</div>

                    <div class="stat-label">Mezun</div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-icon"><i class="fa fa-hand-holding-heart"></i></div>

                    <div class="stat-number counter" data-count="1200">0</div>

                    <div class="stat-label">Bursiyer</div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-icon"><i class="fa fa-eye"></i></div>

                    <div class="stat-number counter" data-count="@ViewBag.ZiyaretciSayisi">0</div>

                    <div class="stat-label">Ziyaret</div>
                </div>
            </div>
        </div>
    </div>
</section>
 
<section class="schools-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 style="font-family:'Playfair Display'; font-weight:800; color:#0a1a5c;">Eğitim Kurumlarımız</h2>
            <div style="width:80px; height:4px; background:#b8860b; margin:10px auto;"></div>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <a href="https://ankara.tfo.k12.tr/lise/" target="_blank" class="text-decoration-none">
                    <div class="school-card card h-100 border-0 shadow-sm">
                        <img src="lib/img/bina1.png" class="card-img-top" alt="Ankara Tevfik Fikret Lisesi">
                        <div class="card-body text-center mt-3">
                            <h5 class="card-title" style="color:#0a1a5c; font-weight:700;">Ankara Tevfik Fikret Lisesi</h5>
                            <p class="card-text text-muted small">Köklü geçmiş, aydınlık gelecek.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 mb-4">
                <a href="https://ankara.tfo.k12.tr/ilkokul/" target="_blank" class="text-decoration-none">
                    <div class="school-card card h-100 border-0 shadow-sm">
                        <img src="~/lib/img/ilkokul.png" class="card-img-top" alt="Ankara Tevfik Fikret İlköğretim">
                        <div class="card-body text-center mt-3">
                            <h5 class="card-title" style="color:#0a1a5c; font-weight:700;">Ankara Tevfik Fikret İlköğretim</h5>
                            <p class="card-text text-muted small">Geleceğin liderleri burada yetişiyor.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 mb-4">
                <a href="https://izmir.tfo.k12.tr" target="_blank" class="text-decoration-none">
                    <div class="school-card card h-100 border-0 shadow-sm">
                        <img src="~/lib/img/lise2.jpg" class="card-img-top" alt="İzmir Tevfik Fikret Lisesi">
                        <div class="card-body text-center mt-3">
                            <h5 class="card-title" style="color:#0a1a5c; font-weight:700;">İzmir Tevfik Fikret Lisesi</h5>
                            <p class="card-text text-muted small">Ege'nin incisinde çağdaş eğitim.</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

@if (Model.SonHaberler != null && Model.SonHaberler.Any())
{
    // İlk haberi "Manşet", geri kalanları (varsa) "Yan Akış" olarak ayırıyoruz
    var mansetHaber = Model.SonHaberler.First();
    var yanHaberler = Model.SonHaberler.Skip(1).ToList();

    <section class="home-news-section bg-light" style="padding: 100px 0;">
        <div class="container">
            
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5 border-bottom pb-3">
                <div>
                    <h6 class="text-gold-header text-uppercase fw-bold mb-2" style="color: var(--renk-altin); letter-spacing: 2px; font-size: 0.9rem;">Güncel Gelişmeler</h6>
                    <h2 class="fw-bold mb-0 text-navy-header" style="color: var(--renk-lacivert); font-family: 'Playfair Display', serif; font-size: 2.5rem;">Haberler & Duyurular</h2>
                </div>
                <div class="mt-3 mt-md-0">
                    <a href="/Haberler/Index" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-bold" style="border-color: var(--renk-lacivert); color: var(--renk-lacivert);">
                        Tüm Arşivi Gör <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-7">
                    <a href="/Haberler/Detay/@mansetHaber.Id" class="text-decoration-none">
                        <div class="main-featured-news h-100 position-relative rounded-4 overflow-hidden shadow-sm">
                            <img src="@(string.IsNullOrEmpty(mansetHaber.FotografYolu) ? "/img/default-news.jpg" : mansetHaber.FotografYolu)" alt="@mansetHaber.Baslik" class="img-fluid w-100 h-100 object-fit-cover main-news-img">
                            
                            <div class="news-gradient-overlay position-absolute bottom-0 start-0 w-100 h-100"></div>

                            <div class="main-news-content position-absolute bottom-0 start-0 w-100 p-4 p-md-5 z-2 text-white">
                                @if(mansetHaber.Kategori != null)
                                {
                                    <span class="badge bg-warning text-dark mb-3 px-3 py-2 fs-6 shadow">@mansetHaber.Kategori.KategoriAdi</span>
                                }
                                <h3 class="fw-bold mb-3" style="font-family: 'Playfair Display', serif; font-size: 2rem; text-shadow: 1px 1px 3px rgba(0,0,0,0.8);">
                                    @mansetHaber.Baslik
                                </h3>
                                <p class="d-none d-md-block text-light mb-0" style="opacity: 0.9;">
                                    @(mansetHaber.Ozet.Length > 120 ? mansetHaber.Ozet.Substring(0, 120) + "..." : mansetHaber.Ozet)
                                </p>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-5">
                    <div class="d-flex flex-column gap-4 h-100 justify-content-between">
                        
                        @foreach (var yanHaber in yanHaberler)
                        {
                            <a href="/Haberler/Detay/@yanHaber.Id" class="side-news-card text-decoration-none d-flex align-items-center bg-white rounded-4 p-3 shadow-sm transition-all">
                                <div class="side-news-img-wrapper rounded-3 overflow-hidden flex-shrink-0" style="width: 120px; height: 120px;">
                                    <img src="@(string.IsNullOrEmpty(yanHaber.FotografYolu) ? "/img/default-news.jpg" : yanHaber.FotografYolu)" class="w-100 h-100 object-fit-cover" alt="@yanHaber.Baslik">
                                </div>
                                <div class="ms-4">
                                    <div class="text-muted small mb-1 fw-bold">
                                        <i class="far fa-calendar-alt text-warning me-1"></i> @(yanHaber.YayimTarihi?.ToString("dd MMMM yyyy") ?? DateTime.Now.ToString("dd MMMM yyyy"))
                                    </div>
                                    <h6 class="fw-bold mb-2" style="color: var(--renk-lacivert); line-height: 1.4;">
                                        @(yanHaber.Baslik.Length > 65 ? yanHaber.Baslik.Substring(0, 65) + "..." : yanHaber.Baslik)
                                    </h6>
                                </div>
                            </a>
                        }

                    </div>
                </div>
            </div>

        </div>
    </section>
}


<section class="heritage-section pt-5 pb-5" style="background-color: var(--renk-gri);">
    <div class="container">
        
        <div class="heritage-image-wrapper">
            <img src="/lib/img/background.png" alt="Ankara Öğretim Derneği Eski Binası" class="img-fluid heritage-img">
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="heritage-content-card">
                    <h6 class="text-gold-header text-uppercase fw-bold mb-3 text-center">Tarihçemiz & Hakkımızda</h6>
                    <h2 class="text-navy-header fw-bold mb-4 text-center">
                        @(Model?.About?.Baslik ?? "1965'ten Gelen Köklü Miras")
                    </h2>
                    
                    <div class="about-text text-center px-md-5">
                        @if (!string.IsNullOrEmpty(Model?.About?.Icerik))
                        {
                            @Html.Raw(Model.About.Icerik)
                        }
                        else
                        {
                            <p>Yarım asrı aşan tecrübemizle aydınlık geleceği inşa etmeye devam ediyoruz. Ankara Öğretim Derneği, Atatürk ilke ve devrimlerine bağlı, laik, çağdaş bireyler yetiştirmeyi amaçlamaktadır.</p>
                        }
                    </div>
                    
                    <div class="text-center mt-4">
                        <a href="/Dernek/Hakkinda/tarihce" class="btn btn-heritage rounded-pill px-5 py-2 fw-bold">
                            Tarihçemizi İnceleyin
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>


@section Scripts {
    <script>
        // jQuery'nin yüklendiğinden emin olalım
        if (typeof jQuery == 'undefined') {
            console.error("HATA: jQuery kütüphanesi sayfada yüklü değil! Layout dosyanızı kontrol edin.");
        } else {
            console.log("Başarılı: jQuery çalışıyor, sayaca başlanıyor...");

            $(document).ready(function () {
                $('.counter').each(function () {
                    var $this = $(this);

                    // Sayıyı al ve sayıya çevir (ParseInt)
                    var countTo = parseInt($this.attr('data-count'));
                    var suffix = $this.attr('data-suffix') || "";

                    console.log("Hedef Sayı: " + countTo); // Konsola yazdırır

                    $({ countNum: 0 }).animate({
                        countNum: countTo
                    },
                    {
                        duration: 2000,
                        easing: 'swing',
                        step: function () {
                            $this.text(Math.ceil(this.countNum).toLocaleString('tr-TR') + suffix);
                        },
                        complete: function () {
                            $this.text(Math.ceil(this.countNum).toLocaleString('tr-TR') + suffix);
                        }
                    });
                });
            });
        }
    </script>
}