</section>

@section Scripts {
    <script>
        // 1. TARAYICININ KAYDIRMA HAFIZASINI KAPAT VE EN ÜSTE ÇIK
        if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual';
        }
        window.scrollTo(0, 0);

        // 2. MODERN SAYAÇ ANİMASYONU
        document.addEventListener("DOMContentLoaded", function() {
            const counters = document.querySelectorAll('.counter');
            const duration = 2000; 

            counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-count')) || 0;
                const suffix = counter.getAttribute('data-suffix') || "";
                let startTimestamp = null;

                const step = (timestamp) => {
                    if (!startTimestamp) startTimestamp = timestamp;
                    
                    const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    const easeProgress = 1 - (1 - progress) * (1 - progress);
                    const currentCount = Math.ceil(easeProgress * target);
                    
                    counter.innerText = currentCount.toLocaleString('tr-TR') + suffix;

                    if (progress < 1) {
                        window.requestAnimationFrame(step);
                    } else {
                        counter.innerText = target.toLocaleString('tr-TR') + suffix;
                    }
                };

                window.requestAnimationFrame(step);
            });
        });
    </script>
}