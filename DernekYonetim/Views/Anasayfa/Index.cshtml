@using DernekYonetim.Models
@model DernekYonetim.Models.HomeViewModel

@{
    ViewData["Title"] = "Anasayfa";
    Layout = "_Layout";
}

<style>
    /* GENEL DEĞİŞKENLER */
    :root {
        --renk-lacivert: #0a1a5c;
        --renk-altin: #b8860b;
        --renk-acik-altin: #d4a017;
        --renk-gri: #f8fafc;
    }

   /* YENİ PROFESYONEL SLIDER AYARLARI */
    .hero-section {
        position: relative;
        width: 100%;
        height: 85vh !important;
        min-height: 650px;
        overflow: hidden;
    }

    .carousel, .carousel-inner, .carousel-item {
        height: 100% !important;
    }

    .carousel-item {
        background-size: cover !important;
        background-position: center center !important;
        background-repeat: no-repeat !important;
        transition: transform 6s ease, opacity 1s ease-in-out !important; 
    }

    .carousel-item.active {
        transform: scale(1.05);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(10, 26, 92, 0.95) 0%, rgba(10, 26, 92, 0.7) 40%, rgba(10, 26, 92, 0.1) 100%);
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        color: white;
        opacity: 0; 
        transform: translateY(30px); 
        animation: fadeUp 1s ease-out forwards;
        animation-delay: 0.5s; 
    }

    @@keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .carousel-item.active .hero-content {
        animation: fadeUp 1s ease-out forwards;
        animation-delay: 0.3s;
    }

    .hero-content .badge {
        font-size: 0.9rem;
        letter-spacing: 2px;
        margin-bottom: 20px;
        background-color: var(--renk-altin);
        color: var(--renk-lacivert);
        padding: 8px 15px;
    }

    .hero-content h1 {
        font-family: 'Playfair Display', serif;
        font-size: 4.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 20px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.3);
    }

    .hero-content p {
        font-size: 1.25rem;
        line-height: 1.8;
        opacity: 0.9;
        margin-bottom: 35px;
        border-left: 4px solid var(--renk-altin);
        padding-left: 20px;
    }

    .btn-hero {
        background-color: var(--renk-altin);
        color: var(--renk-lacivert);
        font-weight: 700;
        letter-spacing: 1px;
        padding: 12px 35px;
        border-radius: 50px;
        transition: all 0.3s ease;
        border: 2px solid var(--renk-altin);
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .btn-hero:hover {
        background-color: transparent;
        color: var(--renk-altin);
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(184, 134, 11, 0.3);
    }

    /* İNDİKATÖR (KAPSÜL NOKTALAR) */
    .carousel-indicators { margin-bottom: 2.5rem; gap: 8px; }
    .carousel-indicators button { width: 10px !important; height: 10px !important; border-radius: 50% !important; background-color: rgba(255, 255, 255, 0.4) !important; border: none !important; margin: 0 !important; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important; }
    .carousel-indicators button.active { width: 35px !important; border-radius: 10px !important; background-color: var(--renk-altin) !important; }

    /* OKLAR */
    .carousel-control-prev, .carousel-control-next { width: 50px; height: 50px; background-color: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 50%; top: 50%; transform: translateY(-50%); transition: all 0.3s ease; opacity: 0; }
    .carousel-control-prev { left: 2%; }
    .carousel-control-next { right: 2%; }
    .hero-section:hover .carousel-control-prev, .hero-section:hover .carousel-control-next { opacity: 1; }
    .carousel-control-prev:hover, .carousel-control-next:hover { background-color: var(--renk-altin); border-color: var(--renk-altin); color: var(--renk-lacivert); }

    @@media (max-width: 991px) {
        .hero-content h1 { font-size: 3rem; }
        .carousel-control-prev, .carousel-control-next { display: none; }
        .overlay { background: linear-gradient(to top, rgba(10, 26, 92, 0.95) 0%, rgba(10, 26, 92, 0.6) 60%, rgba(10, 26, 92, 0.2) 100%); }
    }

    /* İSTATİSTİK BÖLÜMÜ */
    .stats-section { background-color: var(--renk-lacivert); color: white; padding: 60px 0; }
    .stat-item { text-align: center; }
    .stat-number { font-size: 2.5rem; font-weight: 800; color: white; }
    .stat-label { color: var(--renk-altin); text-transform: uppercase; letter-spacing: 1px; margin-top: 5px; }
    .stat-icon i { font-size: 2.5rem; color: var(--renk-altin); margin-bottom: 15px; }

    /* EĞİTİM KURUMLARI */
    .school-card .card-img-top { height: 250px; object-fit: cover; border-radius: 8px 8px 0 0; }
    .school-card { border-radius: 8px; transition: all 0.3s ease-in-out; }
    .school-card:hover { transform: translateY(-10px); box-shadow: 0 10px 20px rgba(10, 26, 92, 0.15) !important; }
    .text-decoration-none { text-decoration: none !important; }

    /* YEPYENİ MODERN HABERLER BÖLÜMÜ */
    .modern-news-section { background-color: #f8fafc; padding: 90px 0; }
    .news-header-title { font-family: 'Playfair Display', serif; color: var(--renk-lacivert); font-weight: 800; font-size: 2.8rem; }
    .btn-view-all { border: 2px solid var(--renk-altin); color: var(--renk-lacivert); font-weight: 600; border-radius: 50px; padding: 12px 30px; transition: all 0.3s; background: transparent; }
    .btn-view-all:hover { background-color: var(--renk-altin); color: var(--renk-lacivert); box-shadow: 0 8px 15px rgba(184, 134, 11, 0.2); transform: translateY(-2px); }

    /* Manşet Kartı (Sol Büyük) */
    .featured-card { border-radius: 24px; overflow: hidden; position: relative; height: 100%; min-height: 500px; box-shadow: 0 15px 35px rgba(10, 26, 92, 0.1); display: block; }
    .featured-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
    .featured-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,26,92,0.95) 0%, rgba(10,26,92,0.3) 50%, transparent 100%); transition: background 0.4s ease; }
    .featured-card:hover .featured-img { transform: scale(1.05); }
    .featured-card:hover .featured-overlay { background: linear-gradient(to top, rgba(10,26,92,0.95) 0%, rgba(10,26,92,0.5) 60%, transparent 100%); }
    .featured-content { position: absolute; bottom: 0; left: 0; width: 100%; padding: 40px; color: white; z-index: 2; }
    .featured-badge { background: rgba(184, 134, 11, 0.85); backdrop-filter: blur(8px); color: white; padding: 8px 18px; border-radius: 50px; font-weight: 600; letter-spacing: 1px; font-size: 0.85rem; display: inline-block; margin-bottom: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
    .featured-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; line-height: 1.3; margin-bottom: 15px; text-shadow: 0 4px 10px rgba(0,0,0,0.4); transition: color 0.3s ease; }
    .featured-card:hover .featured-title { color: var(--renk-altin); }
    .featured-desc { opacity: 0.9; font-size: 1.05rem; line-height: 1.6; margin-bottom: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* Yan Haberler Listesi (Sağ Liste) */
    .side-news-list { display: flex; flex-direction: column; gap: 24px; height: 100%; justify-content: space-between; }
    .side-card { display: flex; align-items: center; background: white; border-radius: 20px; padding: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.03); transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); border: 1px solid rgba(0,0,0,0.03); text-decoration: none; }
    .side-card:hover { transform: translateX(-10px); box-shadow: 0 15px 30px rgba(10, 26, 92, 0.08); border-color: rgba(184, 134, 11, 0.2); }
    .side-img-box { width: 140px; height: 140px; border-radius: 16px; overflow: hidden; flex-shrink: 0; position: relative; }
    .side-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .side-card:hover .side-img { transform: scale(1.1); }
    .side-content { padding-left: 24px; flex-grow: 1; }
    .date-badge { display: inline-flex; align-items: center; color: var(--renk-altin); font-weight: 700; font-size: 0.85rem; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
    .date-badge i { margin-right: 8px; font-size: 1rem; }
    .side-title { font-weight: 700; color: var(--renk-lacivert); font-size: 1.15rem; line-height: 1.5; transition: color 0.3s; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .side-card:hover .side-title { color: var(--renk-altin); }
    .read-more-link { color: var(--renk-lacivert); font-weight: 700; font-size: 0.9rem; display: inline-flex; align-items: center; transition: all 0.3s; opacity: 0.8; }
    .read-more-link i { transition: transform 0.3s; margin-left: 6px; font-size: 0.8rem; }
    .side-card:hover .read-more-link { color: var(--renk-altin); opacity: 1; }
    .side-card:hover .read-more-link i { transform: translateX(5px); }

    /* TARİHÇE */
    .heritage-image-wrapper { width: 100%; border-radius: 20px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.15); margin-bottom: 0; }
    .heritage-img { width: 100%; height: auto; display: block; filter: grayscale(80%) contrast(110%); }
    .heritage-content-card { background: white; padding: 50px; border-radius: 20px; box-shadow: 0 25px 50px rgba(0,0,0,0.08); position: relative; z-index: 10; margin-top: -100px; }
    .btn-heritage { border: 2px solid var(--renk-lacivert); color: var(--renk-lacivert); background-color: transparent; transition: all 0.3s ease-in-out; }
    .btn-heritage:hover { background-color: var(--renk-altin); border-color: var(--renk-altin); color: #ffffff !important; }
    
    @@media (max-width: 991px) {
        .featured-card { min-height: 400px; margin-bottom: 30px; }
        .side-card:hover { transform: translateY(-5px); } /* Mobilde sağa değil yukarı kaysın */
    }
    @@media (max-width: 768px) {
        .heritage-content-card { margin-top: -50px; padding: 30px 20px; }
        .news-header-title { font-size: 2.2rem; }
        .side-card { flex-direction: column; text-align: center; }
        .side-img-box { width: 100%; height: 200px; margin-bottom: 15px; }
        .side-content { padding-left: 0; }
    }
    .about-text {
        display: -webkit-box;
        -webkit-line-clamp: 5;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<header class="hero-section">
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="6000">
        
        <div class="carousel-indicators">
            @if (Model.SliderHaberler != null && Model.SliderHaberler.Any())
            {
                for (int i = 0; i < Model.SliderHaberler.Count; i++)
                {
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                }
            }
            else
            {
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            }
        </div>

        <div class="carousel-inner">
            @if (Model.SliderHaberler != null && Model.SliderHaberler.Any())
            {
                var isFirst = true;
                foreach (var sliderItem in Model.SliderHaberler)
                {
                    <div class="carousel-item @(isFirst ? "active" : "")" style="background-image: url('@(string.IsNullOrEmpty(sliderItem.FotografYolu) ? "/img/default-news.jpg" : sliderItem.FotografYolu)');">
                        <div class="overlay">
                            <div class="container h-100">
                                <div class="row h-100 align-items-center">
                                    <div class="col-12 col-md-10 col-lg-8 offset-lg-1 px-4 px-md-0">
                                        
                                        <div class="hero-content">
                                            <span class="badge text-uppercase rounded-pill shadow-sm">
                                                <i class="fas fa-bullhorn me-1"></i> GÜNCEL GELİŞME
                                            </span>
                                            <h1>
                                                @if(sliderItem.Baslik.Length > 40)
                                                {
                                                    @sliderItem.Baslik.Substring(0, 40)<span style="color:var(--renk-altin);">...</span>
                                                }
                                                else
                                                {
                                                    var kelimeler = sliderItem.Baslik.Split(' ');
                                                    if(kelimeler.Length > 1) {
                                                        var sonKelime = kelimeler[kelimeler.Length - 1];
                                                        var digerKelimeler = string.Join(" ", kelimeler.Take(kelimeler.Length - 1));
                                                        @digerKelimeler <span style="color:var(--renk-altin);">@sonKelime</span>
                                                    } else {
                                                        @sliderItem.Baslik
                                                    }
                                                }
                                            </h1>
                                            <p>
                                                @(sliderItem.Ozet.Length > 150 ? sliderItem.Ozet.Substring(0, 150) + "..." : sliderItem.Ozet)
                                            </p>
                                            <a href="/Haberler/Detay/@sliderItem.Id" class="btn btn-hero">
                                                Haberi İncele <i class="fas fa-arrow-right ms-2"></i>
                                            </a>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    isFirst = false;
                }
            }
            else
            {
                <div class="carousel-item active" style="background-image: url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=2070');">
                    <div class="overlay">
                        <div class="container h-100">
                            <div class="row h-100 align-items-center">
                                <div class="col-12 col-md-10 col-lg-8 offset-lg-1 px-4 px-md-0">
                                    
                                    <div class="hero-content">
                                        <span class="badge text-uppercase rounded-pill shadow-sm">
                                            <i class="fas fa-university me-1"></i> ANKARA ÖĞRETİM DERNEĞİ
                                        </span>
                                        <h1>Eğitimde <span style="color:var(--renk-altin);">Fırsat Eşitliği</span></h1>
                                        <p>Yarım asırdır aydınlık nesiller yetiştirmek için çalışıyoruz. Geleceğe atılan her adımda, Atatürk ilke ve inkılaplarının ışığında yanınızdayız.</p>
                                        <a href="/Dernek/Hakkinda/tarihce" class="btn btn-hero">
                                            Tarihçemizi Keşfet <i class="fas fa-arrow-right ms-2"></i>
                                        </a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <i class="fas fa-chevron-left fs-4"></i>
            <span class="visually-hidden">Önceki</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <i class="fas fa-chevron-right fs-4"></i>
            <span class="visually-hidden">Sonraki</span>
        </button>
    </div>
</header>


<section class="stats-section">
    <div class="container">
        <div class="row justify-content-center g-4">
            
            <div class="col-6 col-md-4 col-lg">
                <div class="stat-item text-center">
                    <div class="stat-icon"><i class="fa fa-university text-warning fa-2x mb-2"></i></div>
                    <div class="stat-number fw-bold fs-3 text-white">@ViewBag.KurulusYili</div>
                    <div class="stat-label text-white-50">Kuruluş Yılı</div>
                </div>
            </div>

            <div class="col-6 col-md-4 col-lg">
                <div class="stat-item text-center">
                    <div class="stat-icon"><i class="fa fa-graduation-cap text-warning fa-2x mb-2"></i></div>
                    <div class="stat-number counter fw-bold fs-3 text-white" data-count="@ViewBag.AnkaraMezunSayisi" data-suffix="+">0</div>
                    <div class="stat-label text-white-50">Ankara Mezun</div>
                </div>
            </div>

            <div class="col-6 col-md-4 col-lg">
                <div class="stat-item text-center">
                    <div class="stat-icon"><i class="fa fa-graduation-cap text-warning fa-2x mb-2"></i></div>
                    <div class="stat-number counter fw-bold fs-3 text-white" data-count="@ViewBag.IzmirMezunSayisi" data-suffix="+">0</div>
                    <div class="stat-label text-white-50">İzmir Mezun</div>
                </div>
            </div>

            <div class="col-6 col-md-4 col-lg">
                <div class="stat-item text-center">
                    <div class="stat-icon"><i class="fa fa-eye text-warning fa-2x mb-2"></i></div>
                    <div class="stat-number counter fw-bold fs-3 text-white" data-count="@ViewBag.ZiyaretciSayisi">0</div>
                    <div class="stat-label text-white-50">Site Ziyareti</div>
                </div>
            </div>

        </div>
    </div>
</section>
 
<section class="schools-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 style="font-family:'Playfair Display'; font-weight:800; color:#0a1a5c;">Eğitim Kurumlarımız</h2>
            <div style="width:80px; height:4px; background:#b8860b; margin:10px auto;"></div>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <a href="https://ankara.tfo.k12.tr/lise/" target="_blank" class="text-decoration-none">
                    <div class="school-card card h-100 border-0 shadow-sm">
                        <img src="lib/img/bina1.png" class="card-img-top" alt="Ankara Tevfik Fikret Lisesi">
                        <div class="card-body text-center mt-3">
                            <h5 class="card-title" style="color:#0a1a5c; font-weight:700;">Ankara Tevfik Fikret Lisesi</h5>
                            <p class="card-text text-muted small">Köklü geçmiş, aydınlık gelecek.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 mb-4">
                <a href="https://ankara.tfo.k12.tr/ilkokul/" target="_blank" class="text-decoration-none">
                    <div class="school-card card h-100 border-0 shadow-sm">
                        <img src="~/lib/img/ilkokul.png" class="card-img-top" alt="Ankara Tevfik Fikret İlköğretim">
                        <div class="card-body text-center mt-3">
                            <h5 class="card-title" style="color:#0a1a5c; font-weight:700;">Ankara Tevfik Fikret İlköğretim</h5>
                            <p class="card-text text-muted small">Geleceğin liderleri burada yetişiyor.</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4 mb-4">
                <a href="https://izmir.tfo.k12.tr" target="_blank" class="text-decoration-none">
                    <div class="school-card card h-100 border-0 shadow-sm">
                        <img src="~/lib/img/lise2.jpg" class="card-img-top" alt="İzmir Tevfik Fikret Lisesi">
                        <div class="card-body text-center mt-3">
                            <h5 class="card-title" style="color:#0a1a5c; font-weight:700;">İzmir Tevfik Fikret Lisesi</h5>
                            <p class="card-text text-muted small">Ege'nin incisinde çağdaş eğitim.</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

@if (Model.SonHaberler != null && Model.SonHaberler.Any())
{
    // İlk haberi "Manşet", geri kalanları (maksimum 3 tane) "Yan Liste" olarak ayırıyoruz.
    var mansetHaber = Model.SonHaberler.First();
    var yanHaberler = Model.SonHaberler.Skip(1).Take(3).ToList();

    <section class="modern-news-section">
        <div class="container">
            
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5">
                <div>
                    <h6 class="text-uppercase fw-bold mb-2" style="color: var(--renk-altin); letter-spacing: 2px; font-size: 0.95rem;">
                        Derneğimizden Haberler
                    </h6>
                    <h2 class="news-header-title mb-0">Güncel Gelişmeler</h2>
                </div>
                <div class="mt-4 mt-md-0">
                    <a href="/Haberler" class="btn btn-view-all text-decoration-none d-inline-flex align-items-center">
                        Tüm Arşivi Gör <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>

            <div class="row g-4">
                
                <div class="col-lg-7">
                    <a href="/Haberler/Detay/@mansetHaber.Id" class="featured-card text-decoration-none">
                        <img src="@(string.IsNullOrEmpty(mansetHaber.FotografYolu) ? "/img/default-news.jpg" : mansetHaber.FotografYolu)" alt="@mansetHaber.Baslik" class="featured-img">
                        <div class="featured-overlay"></div>
                        <div class="featured-content">
                            @if(mansetHaber.Kategori != null)
                            {
                                <div class="featured-badge">
                                    <i class="fas fa-tag me-1"></i> @mansetHaber.Kategori.KategoriAdi
                                </div>
                            }
                            <h3 class="featured-title">@mansetHaber.Baslik</h3>
                            <p class="featured-desc d-none d-md-block">@mansetHaber.Ozet</p>
                        </div>
                    </a>
                </div>

                @if(yanHaberler.Any())
                {
                    <div class="col-lg-5">
                        <div class="side-news-list">
                            @foreach (var yanHaber in yanHaberler)
                            {
                                <a href="/Haberler/Detay/@yanHaber.Id" class="side-card">
                                    <div class="side-img-box">
                                        <img src="@(string.IsNullOrEmpty(yanHaber.FotografYolu) ? "/img/default-news.jpg" : yanHaber.FotografYolu)" class="side-img" alt="@yanHaber.Baslik">
                                    </div>
                                    <div class="side-content">
                                        <div class="date-badge">
                                            <i class="far fa-calendar-alt"></i> 
                                            @(yanHaber.YayimTarihi?.ToString("dd MMM yyyy") ?? DateTime.Now.ToString("dd MMM yyyy"))
                                        </div>
                                        <h4 class="side-title">@yanHaber.Baslik</h4>
                                        <span class="read-more-link">
                                            İncele <i class="fas fa-chevron-right"></i>
                                        </span>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>
    </section>
}

